generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("sdr")
  language  String   @default("fi")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts            Account[]
  sessions            Session[]
  callStories         CallStory[]
  peerSupportRequests PeerSupportRequest[]
  peerSupportAnswers  PeerSupportAnswer[]
}

model ProjectCard {
  id                 String      @id @default(cuid())
  name               String      @unique
  industry           String
  callAngle          String?
  callHistorySummary String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  callStories         CallStory[]
  peerSupportRequests PeerSupportRequest[]
}

model CallStory {
  id            String      @id @default(cuid())
  content       String
  projectCardId String
  userId        String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  projectCard   ProjectCard @relation(fields: [projectCardId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])
}

model PeerSupportRequest {
  id            String      @id @default(cuid())
  projectCardId String
  userId        String
  adviceType    String
  description   String?
  status        String      @default("pending")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  projectCard   ProjectCard @relation(fields: [projectCardId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])
  answers       PeerSupportAnswer[]
}

model PeerSupportAnswer {
  id                   String             @id @default(cuid())
  peerSupportRequestId String
  userId               String
  content              String
  createdAt            DateTime           @default(now())

  peerSupportRequest   PeerSupportRequest @relation(fields: [peerSupportRequestId], references: [id], onDelete: Cascade)
  user                 User               @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
